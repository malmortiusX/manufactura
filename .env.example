# ─── Base de datos SQL Server ──────────────────────────────────────────────────
# Opción 1: Autenticación SQL (usuario y contraseña)
DATABASE_URL="sqlserver://localhost:1433;database=MiBaseDeDatos;user=sa;password=TuPassword;trustServerCertificate=true"

# Opción 2: Windows Integrated Security (solo en Windows)
# DATABASE_URL="sqlserver://localhost:1433;database=MiBaseDeDatos;integratedSecurity=true;trustServerCertificate=true"

# Opción 3: Servidor remoto nombrado
# DATABASE_URL="sqlserver://SERVIDOR\\INSTANCIA:1433;database=MiBaseDeDatos;user=sa;password=TuPassword;trustServerCertificate=true"

# ─── Better Auth ───────────────────────────────────────────────────────────────
# Genera un secreto seguro con: openssl rand -base64 32
BETTER_AUTH_SECRET="cambia-esto-por-un-secreto-seguro-de-32-caracteres"
BETTER_AUTH_URL="http://localhost:3000"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Mi Dashboard"
